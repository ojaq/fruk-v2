CREATE TABLE public.announcements (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  week_id uuid NOT NULL,
  title text NOT NULL,
  greeting text,
  description text,
  terms text,
  status text NOT NULL CHECK (status = ANY (ARRAY['draft'::text, 'active'::text, 'closed'::text])),
  online_date_start date,
  online_date_end date,
  offline_date date,
  delivery_date date,
  delivery_time time without time zone,
  registration_deadline timestamp with time zone,
  max_suppliers_online integer,
  max_suppliers_offline integer,
  max_products_per_supplier integer,
  created_by uuid,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  updated_at timestamp with time zone NOT NULL DEFAULT now(),
  is_deleted boolean NOT NULL DEFAULT false,
  CONSTRAINT announcements_pkey PRIMARY KEY (id),
  CONSTRAINT announcements_week_id_fkey FOREIGN KEY (week_id) REFERENCES public.weeks(id),
  CONSTRAINT announcements_created_by_fkey FOREIGN KEY (created_by) REFERENCES public.users(id)
);
CREATE TABLE public.orders (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  week_id uuid NOT NULL,
  announcement_id uuid NOT NULL,
  registration_id uuid NOT NULL,
  registration_product_id uuid NOT NULL,
  supplier_id uuid NOT NULL,
  channel text NOT NULL CHECK (channel = ANY (ARRAY['online'::text, 'offline'::text])),
  pemesan text,
  jumlah integer NOT NULL,
  harga_satuan numeric NOT NULL,
  total_harga numeric DEFAULT ((jumlah)::numeric * harga_satuan),
  catatan text,
  bayar numeric,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  is_deleted boolean NOT NULL DEFAULT false,
  status text CHECK (status = ANY (ARRAY['open_bill'::text, 'lunas'::text])),
  method text CHECK (method = ANY (ARRAY['qris'::text, 'transfer'::text, 'cash'::text])),
  CONSTRAINT orders_pkey PRIMARY KEY (id),
  CONSTRAINT orders_week_id_fkey FOREIGN KEY (week_id) REFERENCES public.weeks(id),
  CONSTRAINT orders_announcement_id_fkey FOREIGN KEY (announcement_id) REFERENCES public.announcements(id),
  CONSTRAINT orders_registration_id_fkey FOREIGN KEY (registration_id) REFERENCES public.registrations(id),
  CONSTRAINT orders_registration_product_id_fkey FOREIGN KEY (registration_product_id) REFERENCES public.registration_products(id),
  CONSTRAINT orders_supplier_id_fkey FOREIGN KEY (supplier_id) REFERENCES public.users(id)
);
CREATE TABLE public.products (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  owner_id uuid NOT NULL,
  nama_produk text NOT NULL,
  jenis_produk text,
  keterangan text,
  satuan text,
  ukuran numeric,
  hjk numeric NOT NULL,
  hpp numeric NOT NULL,
  aktif boolean NOT NULL DEFAULT true,
  image_url text,
  is_deleted boolean NOT NULL DEFAULT false,
  deleted_at timestamp with time zone,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  updated_at timestamp with time zone NOT NULL DEFAULT now(),
  CONSTRAINT products_pkey PRIMARY KEY (id),
  CONSTRAINT products_owner_id_fkey FOREIGN KEY (owner_id) REFERENCES public.users(id)
);
CREATE TABLE public.registration_products (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  registration_id uuid NOT NULL,
  channel text NOT NULL CHECK (channel = ANY (ARRAY['online'::text, 'offline'::text, 'both'::text])),
  nama_produk text NOT NULL,
  jenis_produk text,
  keterangan text,
  satuan text,
  ukuran numeric,
  hjk numeric NOT NULL,
  hpp numeric NOT NULL,
  image_url text,
  is_active boolean NOT NULL DEFAULT true,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  is_deleted boolean NOT NULL DEFAULT false,
  offline_stock integer,
  product_id uuid,
  CONSTRAINT registration_products_pkey PRIMARY KEY (id),
  CONSTRAINT registration_products_registration_id_fkey FOREIGN KEY (registration_id) REFERENCES public.registrations(id),
  CONSTRAINT fk_registration_products_product FOREIGN KEY (product_id) REFERENCES public.products(id)
);
CREATE TABLE public.registrations (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  announcement_id uuid NOT NULL,
  supplier_id uuid NOT NULL,
  status text NOT NULL CHECK (status = ANY (ARRAY['pending'::text, 'approved'::text, 'rejected'::text])),
  notes text,
  participate_online boolean NOT NULL DEFAULT false,
  participate_offline boolean NOT NULL DEFAULT false,
  use_same_products boolean NOT NULL DEFAULT true,
  reviewed_by uuid,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  updated_at timestamp with time zone NOT NULL DEFAULT now(),
  is_deleted boolean NOT NULL DEFAULT false,
  offline_stock integer,
  adminNotes text,
  CONSTRAINT registrations_pkey PRIMARY KEY (id),
  CONSTRAINT registrations_announcement_id_fkey FOREIGN KEY (announcement_id) REFERENCES public.announcements(id),
  CONSTRAINT registrations_supplier_id_fkey FOREIGN KEY (supplier_id) REFERENCES public.users(id),
  CONSTRAINT registrations_reviewed_by_fkey FOREIGN KEY (reviewed_by) REFERENCES public.users(id)
);
CREATE TABLE public.users (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  name text NOT NULL,
  role text NOT NULL CHECK (role = ANY (ARRAY['dev'::text, 'admin'::text, 'supplier'::text])),
  nama_supplier text,
  nama_bank text,
  no_rekening text,
  nama_penerima text,
  password text,
  is_deleted boolean NOT NULL DEFAULT false,
  deleted_at timestamp with time zone,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  updated_at timestamp with time zone NOT NULL DEFAULT now(),
  CONSTRAINT users_pkey PRIMARY KEY (id)
);
CREATE TABLE public.weeks (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  week_code text NOT NULL UNIQUE,
  is_active boolean NOT NULL DEFAULT true,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  CONSTRAINT weeks_pkey PRIMARY KEY (id)
);